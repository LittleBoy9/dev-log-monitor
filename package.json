{
  "name": "dev-log-monitor",
  "version": "0.1.0-beta.2",
  "description": "Lightweight local log diagnostics for NestJS, Express, and Node.js development with real-time UI, error tracing, and breadcrumbs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./auto": {
      "types": "./dist/auto.d.ts",
      "import": "./dist/auto.mjs",
      "require": "./dist/auto.js"
    }
  },
  "bin": {
    "dev-log": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src/ui"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "test:express": "ts-node --project examples/tsconfig.json examples/express-test.ts",
    "test:nest": "ts-node --project examples/tsconfig.json examples/nestjs-test.ts"
  },
  "keywords": [
    "logging",
    "logger",
    "development",
    "nestjs",
    "express",
    "nodejs",
    "debug",
    "diagnostics",
    "local",
    "tracing",
    "error-tracking",
    "breadcrumbs",
    "stack-trace",
    "real-time",
    "websocket",
    "dashboard",
    "devtools"
  ],
  "author": "Sounak Das",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sounakdas/dev-log.git"
  },
  "bugs": {
    "url": "https://github.com/sounakdas/dev-log/issues"
  },
  "homepage": "https://github.com/sounakdas/dev-log#readme",
  "publishConfig": {
    "tag": "beta",
    "access": "public"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "express": "^4.18.2",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "@nestjs/common": ">=9.0.0",
    "express": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "express": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
