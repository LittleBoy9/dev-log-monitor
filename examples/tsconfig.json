{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "dev-log-monitor": ["../src/index.ts"],
      "dev-log-monitor/auto": ["../src/auto/index.ts"]
    }
  },
  "include": ["./**/*.ts"]
}
